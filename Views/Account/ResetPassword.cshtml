@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<section class="panel auth-panel">
    <div class="panel-heading">
        <h2>Reset Password</h2>
        <p class="panel-subtitle">Enter the one-time token from the forgot password step and set a new strong password.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="message-banner error-banner">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="message-banner success-banner">@Model.SuccessMessage</div>
    }

    <form asp-action="ResetPassword" method="post" class="auth-form">
        @Html.AntiForgeryToken()

        <div class="field-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" type="email" autocomplete="username" />
            <span asp-validation-for="Email" class="form-validation"></span>
        </div>

        <div class="field-group">
            <label asp-for="ResetToken"></label>
            <input asp-for="ResetToken" autocomplete="one-time-code" />
            <span asp-validation-for="ResetToken" class="form-validation"></span>
        </div>

        <div class="field-group">
            <label asp-for="NewPassword"></label>
            <div class="password-shell">
                <input asp-for="NewPassword" type="password" autocomplete="new-password" id="resetPassword" />
                <button type="button" class="password-toggle" data-password-toggle="resetPassword">Show</button>
            </div>
            <span asp-validation-for="NewPassword" class="form-validation"></span>
        </div>

        <div class="field-group">
            <label asp-for="ConfirmNewPassword"></label>
            <div class="password-shell">
                <input asp-for="ConfirmNewPassword" type="password" autocomplete="new-password" id="resetConfirmPassword" />
                <button type="button" class="password-toggle" data-password-toggle="resetConfirmPassword">Show</button>
            </div>
            <span asp-validation-for="ConfirmNewPassword" class="form-validation"></span>
        </div>

        <div class="auth-actions">
            <button type="submit" class="primary-button">Reset Password</button>
            <a class="secondary-button button-link" asp-action="ForgotPassword">Back to Forgot Password</a>
            <a class="secondary-button button-link" asp-action="Login">Sign In</a>
        </div>
    </form>
</section>
