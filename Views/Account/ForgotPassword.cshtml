@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<section class="panel auth-panel">
    <div class="panel-heading">
        <h2>Forgot Password</h2>
        <p class="panel-subtitle">A one-time reset token will be generated for the email if the account exists.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="message-banner error-banner">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="message-banner success-banner">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ResetToken))
    {
        <div class="reset-token-box">
            <span>Reset Token</span>
            <strong>@Model.ResetToken</strong>
            <small>Use this token immediately on the reset password page. Treat it as sensitive.</small>
        </div>
    }

    <form asp-action="ForgotPassword" method="post" class="auth-form">
        @Html.AntiForgeryToken()

        <div class="field-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" type="email" autocomplete="username" />
            <span asp-validation-for="Email" class="form-validation"></span>
        </div>

        <div class="auth-actions">
            <button type="submit" class="primary-button">Generate Reset Token</button>
            <a class="secondary-button button-link" asp-action="ResetPassword">Reset Password</a>
            <a class="secondary-button button-link" asp-action="Login">Back to Sign In</a>
        </div>
    </form>
</section>
