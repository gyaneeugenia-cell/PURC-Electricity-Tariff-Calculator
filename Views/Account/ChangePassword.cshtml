@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<section class="panel auth-panel">
    <div class="panel-heading">
        <h2>Change Password</h2>
        <p class="panel-subtitle">Use a strong password with at least 12 characters, uppercase, lowercase, a number, and a special character.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="message-banner error-banner">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="message-banner success-banner">@Model.SuccessMessage</div>
    }

    <form asp-action="ChangePassword" method="post" class="auth-form">
        @Html.AntiForgeryToken()

        <div class="field-group">
            <label asp-for="CurrentPassword"></label>
            <div class="password-shell">
                <input asp-for="CurrentPassword" type="password" autocomplete="current-password" id="currentPassword" />
                <button type="button" class="password-toggle" data-password-toggle="currentPassword">Show</button>
            </div>
            <span asp-validation-for="CurrentPassword" class="form-validation"></span>
        </div>

        <div class="field-group">
            <label asp-for="NewPassword"></label>
            <div class="password-shell">
                <input asp-for="NewPassword" type="password" autocomplete="new-password" id="newPassword" />
                <button type="button" class="password-toggle" data-password-toggle="newPassword">Show</button>
            </div>
            <span asp-validation-for="NewPassword" class="form-validation"></span>
        </div>

        <div class="field-group">
            <label asp-for="ConfirmNewPassword"></label>
            <div class="password-shell">
                <input asp-for="ConfirmNewPassword" type="password" autocomplete="new-password" id="confirmNewPassword" />
                <button type="button" class="password-toggle" data-password-toggle="confirmNewPassword">Show</button>
            </div>
            <span asp-validation-for="ConfirmNewPassword" class="form-validation"></span>
        </div>

        <div class="auth-actions">
            <button type="submit" class="primary-button">Update Password</button>
            <a class="secondary-button button-link" asp-controller="Home" asp-action="Index">Back to Dashboard</a>
        </div>
    </form>
</section>
