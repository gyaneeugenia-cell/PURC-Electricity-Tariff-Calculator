@using System.Text
@using System.Text.Json
@model CalculatorPageViewModel
@{
    ViewData["Title"] = "PURC Electricity Tariff Reckoner";

    var chartModel = ChartLayoutService.BuildBillTrendChart(Model.TrendRows);
    var periodsForSelectedYear = Model.AllPeriods
        .Where(item => item.CalendarYear == Model.SelectedCalendarYear)
        .OrderBy(item => item.YearId)
        .ToList();
    var orderedTrendYears = Model.TrendYears
        .Distinct()
        .OrderBy(value => value)
        .ToList();
    var showDemandField = TariffCategoryRules.RequiresSltDemand(
        Model.SelectedCategory,
        Model.SelectedCalendarYear,
        Model.SelectedPeriod);
    var trendDemandYears = new List<(int Year, string Period)>();
    var trendCsvHref = string.Empty;
    var trendCsvFileName = string.Empty;

    if (Model.TrendCategory.StartsWith("SLT", StringComparison.OrdinalIgnoreCase))
    {
        foreach (var trendYear in orderedTrendYears)
        {
            var selectedTrendPeriod = Model.TrendPeriodByYear.TryGetValue(trendYear, out var configuredPeriod)
                ? configuredPeriod
                : Model.AllPeriods
                    .Where(item => item.CalendarYear == trendYear)
                    .OrderBy(item => item.YearId)
                    .LastOrDefault()?.Period ?? string.Empty;

            if (!string.IsNullOrWhiteSpace(selectedTrendPeriod) &&
                TariffCategoryRules.RequiresSltDemand(
                    Model.TrendCategory,
                    trendYear,
                    selectedTrendPeriod))
            {
                trendDemandYears.Add((trendYear, selectedTrendPeriod));
            }
        }
    }

    if (Model.HasTrend)
    {
        var csvBuilder = new StringBuilder();
        csvBuilder.AppendLine("Year,Period,Category,Consumption (kWh),Max Demand (kVA),Total Bill (GHS)");

        foreach (var row in Model.TrendRows.OrderBy(item => item.CalendarYear))
        {
            csvBuilder.AppendLine(string.Join(",",
                CsvEscape(row.CalendarYear.ToString()),
                CsvEscape(row.Period),
                CsvEscape(row.Category),
                CsvEscape(row.ConsumptionKwh.ToString("N2")),
                CsvEscape(row.DemandKva?.ToString("N2") ?? "-"),
                CsvEscape(row.TotalBill.ToString("N2"))));
        }

        trendCsvHref = $"data:text/csv;base64,{Convert.ToBase64String(Encoding.UTF8.GetBytes(csvBuilder.ToString()))}";
        var trendStartYear = Model.TrendRows.Min(item => item.CalendarYear);
        var trendEndYear = Model.TrendRows.Max(item => item.CalendarYear);
        trendCsvFileName = $"{Model.TrendCategory.ToLowerInvariant().Replace(" ", "_").Replace("/", "_")}_trend_{trendStartYear}_{trendEndYear}.csv";
    }

    var hasTrendSummary = Model.TrendRows.Count >= 2;
    var firstTrendRow = hasTrendSummary ? Model.TrendRows.First() : null;
    var lastTrendRow = hasTrendSummary ? Model.TrendRows.Last() : null;
    var trendAbsoluteChange = hasTrendSummary && firstTrendRow is not null && lastTrendRow is not null
        ? lastTrendRow.TotalBill - firstTrendRow.TotalBill
        : 0m;
    var trendPercentageChange = hasTrendSummary && firstTrendRow is not null && firstTrendRow.TotalBill != 0m
        ? (trendAbsoluteChange / firstTrendRow.TotalBill) * 100m
        : 0m;
    var trendChangeClass = trendAbsoluteChange > 0m
        ? "positive"
        : trendAbsoluteChange < 0m
            ? "negative"
            : "neutral";
    var trendAbsoluteChangeText = FormatSignedAmount(trendAbsoluteChange);
    var trendPercentageChangeText = FormatSignedPercentage(trendPercentageChange);
    var selectedRateRows = Model.SelectedTariffBundle is not null
        ? BuildTariffRateDisplayRows(Model.SelectedCategory, Model.SelectedTariffBundle.Components)
        : Array.Empty<TariffRateDisplayRow>();
    var calculationFlowText = Model.CalculationResult is not null
        ? GetCalculationFlowText(Model.CalculationResult.IsReverseCalculation)
        : GetCalculationFlowText(string.Equals(Model.Mode, "TotalBill", StringComparison.OrdinalIgnoreCase));
    var taxBasisNote = BuildTaxBasisNote(Model.SelectedTariffBundle);
    var levyBasisNote = BuildLevyBasisNote(Model.SelectedCalendarYear, Model.SelectedTariffBundle);
    var currentUserDisplayName = User.Identity?.Name ?? "Unknown user";

    var assistantContext = new
    {
        year = Model.SelectedCalendarYear,
        period = Model.SelectedPeriod,
        category = Model.SelectedCategory,
        mode = Model.Mode,
        hasResults = Model.HasResults,
        result = Model.CalculationResult is null
            ? null
            : new
            {
                consumptionKwh = Model.CalculationResult.ConsumptionKwh,
                totalBill = Model.CalculationResult.TotalBill,
                demandKva = Model.CalculationResult.DemandKva,
                isReverseCalculation = Model.CalculationResult.IsReverseCalculation,
                breakdown = Model.CalculationResult.Breakdown.Select(line => new { line.Label, line.Amount }),
            },
    };
}

<script id="assistantPageContext" type="application/json">@Html.Raw(JsonSerializer.Serialize(assistantContext))</script>

<header class="purc-hero">
    <div class="purc-ribbon">
        <span>PUBLIC UTILITIES REGULATORY COMMISSION</span>
        <span>Protecting the interest of consumers and utility service providers</span>
    </div>
    <div class="purc-brand-card">
        <div class="purc-brand">
            <img src="@Url.Content("~/images/purc_logo.png")" alt="PURC logo" class="purc-logo" />
            <div class="purc-brand-copy">
                <h1>PURC Electricity Tariff Reckoner</h1>
                <p>Tariff reckoning, reverse billing, bill breakdown printing, and multi-year comparison platform.</p>
            </div>
        </div>
    </div>
</header>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="message-banner error-banner">@Model.ErrorMessage</div>
}

<section class="panel panel-config">
    <form asp-action="Calculate" method="post" class="config-grid" id="calculatorForm">
        @Html.AntiForgeryToken()

        <div class="field-group compact-field">
            <label for="SelectedCalendarYear">Year</label>
            <select asp-for="SelectedCalendarYear" id="calendarYearSelect" data-refresh-on-change="true">
                @foreach (var year in Model.AvailableYears)
                {
                    <option value="@year">@year</option>
                }
            </select>
        </div>

        <div class="field-group compact-field">
            <label for="SelectedPeriod">Tariff Effective Period</label>
            <select asp-for="SelectedPeriod" id="periodSelect" data-refresh-on-change="true">
                @foreach (var periodItem in periodsForSelectedYear)
                {
                    <option value="@periodItem.Period" data-year-id="@periodItem.YearId">@periodItem.Period</option>
                }
            </select>
            <input asp-for="SelectedYearId" type="hidden" id="selectedYearId" />
        </div>

        <div class="field-group compact-field">
            <label for="SelectedCategory">Category</label>
            <select asp-for="SelectedCategory" id="categorySelect" data-refresh-on-change="true">
                @foreach (var category in Model.AvailableCategories)
                {
                    <option value="@category.Code">@category.Label</option>
                }
            </select>
        </div>

        <div class="field-group compact-field preference-field">
            <label>Preference</label>
            <div class="preference-cards" id="modeCards">
                <label class="preference-card @(string.Equals(Model.Mode, "Consumption", StringComparison.OrdinalIgnoreCase) ? "is-selected" : null)">
                    <input asp-for="Mode" type="radio" value="Consumption" />
                    <span class="preference-card-icon">&#9889;</span>
                    <span class="preference-card-copy">
                        <strong>Consumption</strong>
                        <small>Bill from kWh input</small>
                    </span>
                </label>
                <label class="preference-card @(string.Equals(Model.Mode, "TotalBill", StringComparison.OrdinalIgnoreCase) ? "is-selected" : null)">
                    <input asp-for="Mode" type="radio" value="TotalBill" />
                    <span class="preference-card-icon">&#8373;</span>
                    <span class="preference-card-copy">
                        <strong>Total Bill</strong>
                        <small>Reverse-calculate kWh</small>
                    </span>
                </label>
            </div>
        </div>

        <div class="field-group compact-field" id="consumptionField" style="display:@(string.Equals(Model.Mode, "Consumption", StringComparison.OrdinalIgnoreCase) ? "flex" : "none")">
            <label for="ConsumptionKwh">Monthly Consumption (kWh)</label>
            <input asp-for="ConsumptionKwh" type="text" inputmode="decimal" pattern="[0-9]*[.]?[0-9]*" data-sanitize-number="decimal" />
        </div>

        <div class="field-group compact-field" id="totalBillField" style="display:@(string.Equals(Model.Mode, "TotalBill", StringComparison.OrdinalIgnoreCase) ? "flex" : "none")">
            <label for="TotalBillInput">Total Monthly Bill (GHS)</label>
            <input asp-for="TotalBillInput" type="text" inputmode="decimal" pattern="[0-9]*[.]?[0-9]*" data-sanitize-number="decimal" />
        </div>

        <div class="field-group compact-field" id="demandField" style="display:@(showDemandField ? "flex" : "none")">
            <label for="DemandKva">Maximum Demand (kVA)</label>
            <input asp-for="DemandKva" type="number" step="1" min="0" inputmode="numeric" data-sanitize-number="integer" />
        </div>

        <div class="actions-row config-actions">
            <button type="submit" class="primary-button">Calculate</button>
            <input asp-for="ShowTrendTools" type="checkbox" id="ShowTrendTools" class="visually-hidden" />
            <label for="ShowTrendTools" class="primary-button trend-tool-button @(Model.ShowTrendTools ? "is-active" : null)">
                <span class="trend-tool-button-icon">&#128200;</span>
                <span>Bill Trend Tool</span>
            </label>
            @if (Model.HasResults)
            {
                <button type="button" class="secondary-button" onclick="window.print()">Print Bill Breakdown</button>
            }
        </div>
    </form>
</section>

@if (Model.SelectedTariffBundle is not null)
{
    <section class="panel rates-inspector-panel">
        <div class="panel-heading panel-heading-split">
            <div>
                <h2>Selected Tariff Rates</h2>
                <p class="panel-subtitle">@Model.SelectedCalendarYear | @Model.SelectedPeriod | @Model.SelectedCategory</p>
            </div>
            <button type="button" class="secondary-button" id="toggleRatesButton">Show Tariff Rates</button>
        </div>

        <div class="rates-panel-body is-hidden" id="tariffRatesPanel">
            <div class="rates-meta-grid">
                <div class="rate-meta-card">
                    <span>Year</span>
                    <strong>@Model.SelectedCalendarYear</strong>
                </div>
                <div class="rate-meta-card">
                    <span>Effective Period</span>
                    <strong>@Model.SelectedPeriod</strong>
                </div>
                <div class="rate-meta-card">
                    <span>Category</span>
                    <strong>@Model.SelectedCategory</strong>
                </div>
                <div class="rate-meta-card">
                    <span>Timestamp</span>
                    <strong>@Model.PageTimestamp.ToString("dd MMM yyyy HH:mm:ss")</strong>
                </div>
            </div>

            <div class="rates-tables-grid">
                <div class="rates-table-column">
                    <div class="rates-table-card rates-table-card-wide">
                        <h3>Tariff Components</h3>
                        <table class="rate-sheet-table rate-component-table">
                            <colgroup>
                                <col class="rate-sheet-category-col" />
                                <col class="rate-sheet-measure-col" />
                                <col class="rate-sheet-tariff-col" />
                            </colgroup>
                            <thead>
                                <tr>
                                    <th>Customer Category</th>
                                    <th>Measure</th>
                                    <th>Tariff</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="rate-effective-row">
                                    <td></td>
                                    <td></td>
                                    <td class="rate-effective-value">@Model.SelectedPeriod</td>
                                </tr>
                                @foreach (var row in selectedRateRows)
                                {
                                    if (row.IsSection)
                                    {
                                        <tr class="rate-section-row">
                                            <td>@row.CustomerCategory</td>
                                            <td></td>
                                            <td></td>
                                        </tr>
                                    }
                                    else
                                    {
                                        <tr>
                                            <td>@row.CustomerCategory</td>
                                            <td>@row.Measure</td>
                                            <td>@row.NewTariff</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="rates-table-card">
                        <h3>Taxes and Levies</h3>
                        <table class="rate-sheet-table rate-sheet-table-compact">
                            <colgroup>
                                <col class="rate-sheet-tax-charge-col" />
                                <col class="rate-sheet-tax-rate-col" />
                            </colgroup>
                            <thead>
                                <tr>
                                    <th>Charge</th>
                                    <th>Rate</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.SelectedTariffBundle.Tax is not null)
                                {
                                    <tr>
                                        <td>Tax</td>
                                        <td>@FormatRatePercentage(Model.SelectedTariffBundle.Tax.TaxRate)</td>
                                    </tr>
                                }
                                @foreach (var levy in Model.SelectedTariffBundle.Levies)
                                {
                                    <tr>
                                        <td>@levy.LevyName</td>
                                        <td>@FormatLevyDisplay(Model.SelectedCalendarYear, levy)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <div class="rates-note-stack">
                            <p class="rates-note">@taxBasisNote</p>
                            <p class="rates-note">@levyBasisNote</p>
                        </div>
                    </div>
                </div>

                <aside class="rates-visual-stage" aria-hidden="true">
                    <div class="tariff-motion-card tariff-motion-card-minimal @GetMotionVariantClass(Model.SelectedCategory)" data-tilt-card>
                        <div class="tariff-motion-stage">
                            <span class="tariff-motion-shadow"></span>
                            <span class="tariff-motion-orb"></span>
                            <span class="tariff-motion-ring tariff-motion-ring-one"></span>
                            <span class="tariff-motion-ring tariff-motion-ring-two"></span>
                            <span class="tariff-motion-glyph">@Html.Raw(GetAnimatedVisualMarkup(Model.SelectedCategory))</span>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </section>
}

@if (Model.HasResults && Model.CalculationResult is not null)
{
    <section class="results-layout">
        <div class="panel breakdown-panel">
            <h2>Bill Breakdown</h2>
            <div class="bill-breakdown-meta">
                <div class="bill-breakdown-meta-item">
                    <span>Prepared By</span>
                    <strong>@currentUserDisplayName</strong>
                </div>
                <div class="bill-breakdown-meta-item">
                    <span>Tariff Period</span>
                    <strong>@Model.CalculationResult.Period</strong>
                </div>
                <div class="bill-breakdown-meta-item">
                    <span>Printed</span>
                    <strong>@Model.PageTimestamp.ToString("dd MMM yyyy HH:mm:ss")</strong>
                </div>
            </div>
            <table class="breakdown-table">
                <thead>
                    <tr>
                        <th>Component</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in Model.CalculationResult.Breakdown)
                    {
                        <tr>
                            <td>@line.Label</td>
                            <td>GHS @line.Amount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="panel results-panel">
            <h2>Results</h2>
            <div class="category-chip">
                <span class="category-chip-icon">@Html.Raw(GetCategoryIconMarkup(Model.CalculationResult.Category))</span>
                <span>@Model.CalculationResult.Category</span>
            </div>

            <div class="results-meta-grid">
                <div class="result-meta-card">
                    <span>Year</span>
                    <strong>@Model.CalculationResult.CalendarYear</strong>
                </div>
                <div class="result-meta-card">
                    <span>Effective Tariff Period</span>
                    <strong>@Model.CalculationResult.Period</strong>
                </div>
                <div class="result-meta-card">
                    <span>Preference</span>
                    <strong>@calculationFlowText</strong>
                </div>
                <div class="result-meta-card">
                    <span>Timestamp</span>
                    <strong>@Model.PageTimestamp.ToString("dd MMM yyyy HH:mm:ss")</strong>
                </div>
            </div>

            <div class="metric-stack">
                <div class="metric-block">
                    <div class="metric-label">Total Bill (GHS)</div>
                    <div class="metric-value">@Model.CalculationResult.TotalBill.ToString("N2")</div>
                </div>

                <div class="metric-block">
                    <div class="metric-label">
                        @(Model.CalculationResult.IsReverseCalculation ? "Estimated Consumption (kWh)" : "Consumption (kWh)")
                    </div>
                    <div class="metric-value">@Model.CalculationResult.ConsumptionKwh.ToString("N2")</div>
                </div>
            </div>
        </div>
    </section>
}

<section class="panel trend-panel @(Model.ShowTrendTools ? string.Empty : "is-hidden")" id="trendToolsPanel">
    <div class="panel-heading panel-heading-split">
        <div>
            <h2>Bill Trend</h2>
            <p class="panel-subtitle">Compare how the total bill changes across years for the same consumption level.</p>
        </div>
        <button type="button" class="secondary-button" id="closeTrendToolsButton">Close Trend Tools</button>
    </div>

    <form asp-action="Trend" method="post" class="trend-grid" id="trendForm">
        @Html.AntiForgeryToken()
        <input asp-for="SelectedCalendarYear" type="hidden" />
        <input asp-for="SelectedYearId" type="hidden" />
        <input asp-for="SelectedPeriod" type="hidden" />
        <input asp-for="SelectedCategory" type="hidden" />
        <input asp-for="Mode" type="hidden" />
        <input asp-for="ConsumptionKwh" type="hidden" />
        <input asp-for="TotalBillInput" type="hidden" />
        <input asp-for="DemandKva" type="hidden" />
        <input asp-for="ShowTrendTools" type="hidden" value="true" />

        <div class="field-group compact-field">
            <label for="TrendCategory">Trend Category</label>
            <select asp-for="TrendCategory" id="TrendCategory" class="trend-refresh-control">
                @foreach (var category in Model.AvailableCategories.Where(item => item.Code == "Residential" || item.Code == "Non-Residential" || item.Code.StartsWith("SLT", StringComparison.OrdinalIgnoreCase)))
                {
                    <option value="@category.Code">@category.Label</option>
                }
            </select>
        </div>

        <div class="field-group compact-field">
            <label for="TrendConsumptionKwh">Trend Consumption (kWh)</label>
            <input asp-for="TrendConsumptionKwh" type="text" inputmode="decimal" pattern="[0-9]*[.]?[0-9]*" data-sanitize-number="decimal" />
        </div>

        <div class="field-group trend-years-field">
            <label for="TrendYearsSelect">Years to Compare</label>
            <select id="TrendYearsSelect" name="TrendYears" multiple size="6" class="trend-years-select trend-refresh-control">
                @foreach (var year in Model.AvailableYears.OrderBy(value => value))
                {
                    <option value="@year" selected="@(Model.TrendYears.Contains(year) ? "selected" : null)">@year</option>
                }
            </select>
            <small class="field-hint">Hold Ctrl while selecting multiple years.</small>
        </div>

        @if (orderedTrendYears.Count > 0)
        {
            <div class="trend-periods-grid">
                @foreach (var trendYear in orderedTrendYears)
                {
                    var periodsForTrendYear = Model.AllPeriods
                        .Where(item => item.CalendarYear == trendYear)
                        .OrderBy(item => item.YearId)
                        .ToList();
                    var selectedTrendPeriod = Model.TrendPeriodByYear.TryGetValue(trendYear, out var configuredPeriod)
                        ? configuredPeriod
                        : periodsForTrendYear.LastOrDefault()?.Period ?? string.Empty;

                    <div class="field-group compact-field">
                        <label for="trend-period-@trendYear">@trendYear Tariff Period</label>
                        <select id="trend-period-@trendYear" name="TrendPeriodByYear[@trendYear]" class="trend-period-select trend-refresh-control">
                            @foreach (var trendPeriod in periodsForTrendYear)
                            {
                                <option value="@trendPeriod.Period" selected="@(string.Equals(trendPeriod.Period, selectedTrendPeriod, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@trendPeriod.Period</option>
                            }
                        </select>
                    </div>
                }
            </div>
        }

        <div class="trend-options-row">
            <div class="field-group checkbox-field trend-option-cell">
                <label class="checkbox-label">
                    <input asp-for="ShowTrendTable" type="checkbox" />
                    <span>Show trend data table</span>
                </label>
            </div>
        </div>

        @if (trendDemandYears.Count > 0)
        {
            <div class="trend-demand-section">
                <h3>Required Maximum Demand Inputs</h3>
                <div class="trend-demand-grid">
                    @foreach (var demandYear in trendDemandYears)
                    {
                        <div class="field-group compact-field">
                            <label for="trend-demand-@demandYear.Year">@demandYear.Year Max Demand (kVA)</label>
                            <input
                                id="trend-demand-@demandYear.Year"
                                type="number"
                                step="1"
                                min="0"
                                inputmode="numeric"
                                data-sanitize-number="integer"
                                name="TrendDemandByYear[@demandYear.Year]"
                                value="@(Model.TrendDemandByYear.TryGetValue(demandYear.Year, out var demand) ? demand.ToString("0.##") : "0")" />
                            <small class="field-hint">@demandYear.Period</small>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="actions-row">
            <button type="submit" class="primary-button">Generate Bill Trend</button>
        </div>
    </form>

    @if (Model.HasTrend)
    {
        if (Model.ShowTrendTable)
        {
            <div class="trend-table-wrap">
                <div class="panel-heading panel-heading-split trend-download-heading">
                    <h3>Trend Table</h3>
                    <a class="secondary-button button-link" href="@trendCsvHref" download="@trendCsvFileName">Export CSV</a>
                </div>
                <table class="breakdown-table trend-table">
                    <thead>
                        <tr>
                            <th>Year</th>
                            <th>Period</th>
                            <th>Category</th>
                            <th>Consumption (kWh)</th>
                            <th>Max Demand (kVA)</th>
                            <th>Total Bill (GHS)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.TrendRows)
                        {
                            <tr>
                                <td>@row.CalendarYear</td>
                                <td>@row.Period</td>
                                <td>@row.Category</td>
                                <td>@row.ConsumptionKwh.ToString("N2")</td>
                                <td>@(row.DemandKva.HasValue ? row.DemandKva.Value.ToString("N2") : "-")</td>
                                <td>@row.TotalBill.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="chart-card">
            <div class="chart-card-heading">
                <h3>@Model.TrendCategory Bill Trend</h3>
                <div class="chart-export-actions">
                    <button type="button" class="secondary-button chart-export-button" data-chart-export="png">Export PNG</button>
                    <button type="button" class="secondary-button chart-export-button" data-chart-export="jpeg">Export JPEG</button>
                </div>
            </div>
            <svg viewBox="0 0 @chartModel.Width @chartModel.Height" class="trend-svg" role="img" aria-label="Bill trend chart">
                @foreach (var tick in chartModel.YTicks)
                {
                    var plotHeight = chartModel.Height - chartModel.PlotTop - chartModel.PlotBottom;
                    var normalized = chartModel.MaxY == chartModel.MinY ? 0.5m : (tick - chartModel.MinY) / (chartModel.MaxY - chartModel.MinY);
                    var y = chartModel.PlotTop + plotHeight - (normalized * plotHeight);
                    <line x1="@chartModel.PlotLeft" y1="@y" x2="@(chartModel.Width - chartModel.PlotRight)" y2="@y" class="grid-line"></line>
                    @Html.Raw($"<text x=\"{(chartModel.PlotLeft - 12)}\" y=\"{(y + 5)}\" text-anchor=\"end\" class=\"axis-text\">{tick:N0}</text>")
                }

                <line x1="@chartModel.PlotLeft" y1="@chartModel.PlotTop" x2="@chartModel.PlotLeft" y2="@(chartModel.Height - chartModel.PlotBottom)" class="axis-line"></line>
                <line x1="@chartModel.PlotLeft" y1="@(chartModel.Height - chartModel.PlotBottom)" x2="@(chartModel.Width - chartModel.PlotRight)" y2="@(chartModel.Height - chartModel.PlotBottom)" class="axis-line"></line>

                <polyline points="@chartModel.PolylinePoints" class="trend-polyline"></polyline>

                @foreach (var point in chartModel.Points)
                {
                    var labelText = point.Value.ToString("N2");
                    var labelWidth = Math.Max(46m, labelText.Length * 7.4m);
                    var labelHeight = 21m;
                    var labelX = point.X - (labelWidth / 2m);
                    var labelY = point.Y - chartModel.LabelOffset - 16m;

                    <circle cx="@point.X" cy="@point.Y" r="7" class="trend-point"></circle>
                    <rect x="@labelX" y="@labelY" width="@labelWidth" height="@labelHeight" rx="7" ry="7" class="point-label-bg"></rect>
                    @Html.Raw($"<text x=\"{point.X}\" y=\"{(point.Y - chartModel.LabelOffset)}\" text-anchor=\"middle\" class=\"point-label\">{labelText}</text>")
                    @Html.Raw($"<text x=\"{point.X}\" y=\"{(chartModel.Height - chartModel.PlotBottom + 28)}\" text-anchor=\"middle\" class=\"axis-text\">{point.Label}</text>")
                }

                @Html.Raw($"<text x=\"{(chartModel.Width / 2)}\" y=\"{(chartModel.Height - 10)}\" text-anchor=\"middle\" class=\"axis-title\">Year</text>")
                @Html.Raw($"<text x=\"26\" y=\"{(chartModel.Height / 2)}\" text-anchor=\"middle\" class=\"axis-title\" transform=\"rotate(-90 26 {(chartModel.Height / 2)})\">Bill (GHS)</text>")
            </svg>
        </div>

        @if (hasTrendSummary && firstTrendRow is not null && lastTrendRow is not null)
        {
            <div class="trend-summary-wrap">
                <div class="trend-summary-card">
                    <div class="trend-summary-label">First Bill (GHS)</div>
                    <div class="trend-summary-value">@firstTrendRow.TotalBill.ToString("N2")</div>
                    <div class="trend-summary-note neutral">Earliest selected year</div>
                </div>
                <div class="trend-summary-card">
                    <div class="trend-summary-label">Latest Bill (GHS)</div>
                    <div class="trend-summary-value">@lastTrendRow.TotalBill.ToString("N2")</div>
                    <div class="trend-summary-note neutral">Most recent selected year</div>
                </div>
                <div class="trend-summary-card">
                    <div class="trend-summary-label">Overall Change</div>
                    <div class="trend-summary-value @trendChangeClass">@trendAbsoluteChangeText</div>
                    <div class="trend-summary-note @trendChangeClass">@trendPercentageChangeText vs first bill</div>
                </div>
            </div>
        }
    }
</section>

@functions {
    private sealed record TariffRateDisplayRow(
        string CustomerCategory,
        string Measure,
        string NewTariff,
        bool IsSection = false,
        string? Detail = null);

    private static string CsvEscape(string? value)
    {
        var safeValue = value ?? string.Empty;
        if (safeValue.Contains('"') || safeValue.Contains(',') || safeValue.Contains('\n'))
        {
            return "\"" + safeValue.Replace("\"", "\"\"") + "\"";
        }

        return safeValue;
    }

    private static IReadOnlyList<TariffRateDisplayRow> BuildTariffRateDisplayRows(
        string category,
        IReadOnlyList<TariffComponent> components)
    {
        var orderedComponents = components
            .OrderBy(GetComponentSortOrder)
            .ThenBy(component => component.BlockStart ?? 0)
            .ThenBy(component => component.BlockEnd ?? int.MaxValue)
            .ToList();

        var rows = new List<TariffRateDisplayRow>();

        if (category.StartsWith("Residential", StringComparison.OrdinalIgnoreCase))
        {
            rows.Add(new TariffRateDisplayRow("Residential Customer Group:", string.Empty, string.Empty, true));

            var lifelineComponents = orderedComponents
                .Where(component => component.ComponentType.Contains("lifeline", StringComparison.OrdinalIgnoreCase))
                .ToList();

            var firstEnergyBand = orderedComponents
                .FirstOrDefault(component =>
                    component.ComponentType.Equals("energy", StringComparison.OrdinalIgnoreCase) &&
                    component.BlockStart == 0 &&
                    component.BlockEnd is <= 30);

            if (firstEnergyBand is not null && !lifelineComponents.Contains(firstEnergyBand))
            {
                lifelineComponents.Insert(0, firstEnergyBand);
            }

            var otherResidentialComponents = orderedComponents
                .Where(component => !lifelineComponents.Contains(component))
                .ToList();

            if (lifelineComponents.Count > 0)
            {
                rows.Add(new TariffRateDisplayRow("Lifeline Customers:", string.Empty, string.Empty, true));
                rows.AddRange(lifelineComponents.Select(BuildTariffRateRow));
            }

            if (otherResidentialComponents.Count > 0)
            {
                rows.Add(new TariffRateDisplayRow("All Other Residential Customers:", string.Empty, string.Empty, true));
                rows.AddRange(otherResidentialComponents.Select(BuildTariffRateRow));
            }

            return rows;
        }

        if (category.StartsWith("Non-Residential", StringComparison.OrdinalIgnoreCase))
        {
            rows.Add(new TariffRateDisplayRow("Non-Residential Customers:", string.Empty, string.Empty, true));
            rows.AddRange(orderedComponents.Select(BuildTariffRateRow));
            return rows;
        }

        if (category.StartsWith("SLT", StringComparison.OrdinalIgnoreCase))
        {
            rows.Add(new TariffRateDisplayRow("Special Load Tariff (SLT) Customers:", string.Empty, string.Empty, true));
            rows.Add(new TariffRateDisplayRow(GetSltCategoryHeading(category), string.Empty, string.Empty, true));

            var energyComponent = orderedComponents
                .FirstOrDefault(component => IsMatchingSltEnergyComponent(category, component));

            var serviceComponent = orderedComponents
                .FirstOrDefault(component => IsMatchingSltServiceComponent(category, component));

            var demandComponent = orderedComponents
                .FirstOrDefault(component => IsMatchingSltDemandComponent(category, component));

            if (energyComponent is not null)
            {
                rows.Add(new TariffRateDisplayRow(
                    "Energy Charge per kWh",
                    GetMeasureText(energyComponent),
                    energyComponent.Rate.ToString("N4"),
                    false));
            }

            if (serviceComponent is not null)
            {
                rows.Add(new TariffRateDisplayRow(
                    "Service Charge",
                    GetMeasureText(serviceComponent),
                    serviceComponent.Rate.ToString("N4"),
                    false));
            }

            if (demandComponent is not null)
            {
                rows.Add(new TariffRateDisplayRow(
                    "Maximum Demand Charge",
                    GetMeasureText(demandComponent),
                    demandComponent.Rate.ToString("N4"),
                    false));
            }

            return rows;
        }

        if (category.StartsWith("EV", StringComparison.OrdinalIgnoreCase))
        {
            rows.Add(new TariffRateDisplayRow("EV Charging", string.Empty, string.Empty, true));
            rows.AddRange(orderedComponents.Select(BuildTariffRateRow));
            return rows;
        }

        rows.Add(new TariffRateDisplayRow(category, string.Empty, string.Empty, true));
        rows.AddRange(orderedComponents.Select(BuildTariffRateRow));
        return rows;
    }

    private static TariffRateDisplayRow BuildTariffRateRow(TariffComponent component)
    {
        return new TariffRateDisplayRow(
            GetComponentDisplayName(component),
            GetMeasureText(component),
            component.Rate.ToString("N4"),
            false,
            string.IsNullOrWhiteSpace(component.Notes) ? null : component.Notes);
    }

    private static bool IsMatchingSltEnergyComponent(string category, TariffComponent component)
    {
        return MatchesLevelScopedComponent(category, component.ComponentType, "energy");
    }

    private static bool IsMatchingSltServiceComponent(string category, TariffComponent component)
    {
        return MatchesLevelScopedComponent(category, component.ComponentType, "service_charge");
    }

    private static bool IsMatchingSltDemandComponent(string category, TariffComponent component)
    {
        return MatchesLevelScopedComponent(category, component.ComponentType, "demand_charge");
    }

    private static bool MatchesLevelScopedComponent(string category, string componentType, string baseComponentType)
    {
        if (!category.StartsWith("SLT", StringComparison.OrdinalIgnoreCase) &&
            !category.StartsWith("EV", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var normalizedType = componentType.ToLowerInvariant();
        var normalizedLevel = TariffCategoryRules.GetRateLevel(category);
        var preferredMatches = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            $"{baseComponentType}_{normalizedLevel}",
        };

        if (string.Equals(category, "SLT-MV", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(category, "SLT-MV-HV", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(category, "SLT-HV", StringComparison.OrdinalIgnoreCase))
        {
            preferredMatches.Add($"{baseComponentType}_mv_hv");
        }

        if (string.Equals(category, "SLT-MV2", StringComparison.OrdinalIgnoreCase))
        {
            preferredMatches.Add($"{baseComponentType}_mv2");
            preferredMatches.Add($"{baseComponentType}_mv_hv");
        }

        return preferredMatches.Contains(normalizedType);
    }

    private static string GetTariffDisplayText(TariffRateDisplayRow row)
    {
        if (string.IsNullOrWhiteSpace(row.NewTariff))
        {
            return row.Measure;
        }

        if (string.IsNullOrWhiteSpace(row.Measure))
        {
            return row.NewTariff;
        }

        return $"{row.NewTariff} {row.Measure}";
    }

    private static string GetComponentDisplayName(TariffComponent component)
    {
        var componentType = component.ComponentType;

        if (componentType.Contains("service_charge", StringComparison.OrdinalIgnoreCase))
        {
            return "Service Charge";
        }

        if (componentType.Contains("fixed_charge", StringComparison.OrdinalIgnoreCase))
        {
            return "Fixed Charge";
        }

        if (componentType.Contains("demand_charge", StringComparison.OrdinalIgnoreCase))
        {
            return "Maximum Demand Charge";
        }

        if (componentType.StartsWith("energy", StringComparison.OrdinalIgnoreCase))
        {
            if (component.BlockStart.HasValue || component.BlockEnd.HasValue)
            {
                return BuildBlockLabel(component);
            }

            return "Energy Charge per kWh";
        }

        return componentType.Replace("_", " ", StringComparison.Ordinal).Trim();
    }

    private static string GetMeasureText(TariffComponent component)
    {
        if (!string.IsNullOrWhiteSpace(component.Unit))
        {
            return component.Unit!;
        }

        if (component.ComponentType.Contains("service_charge", StringComparison.OrdinalIgnoreCase) ||
            component.ComponentType.Contains("fixed_charge", StringComparison.OrdinalIgnoreCase))
        {
            return "GHS/Month";
        }

        if (component.ComponentType.Contains("demand_charge", StringComparison.OrdinalIgnoreCase))
        {
            return "GHS/kVA";
        }

        return "GHS/kWh";
    }

    private static string BuildBlockLabel(TariffComponent component)
    {
        if (component.BlockStart is null && component.BlockEnd is null)
        {
            return "Flat Rate";
        }

        if (component.BlockEnd is null)
        {
            return $"{component.BlockStart ?? 0}+ kWh";
        }

        if (component.ComponentType.Contains("lifeline", StringComparison.OrdinalIgnoreCase) &&
            component.BlockStart == 0 &&
            component.BlockEnd == 30)
        {
            return "0 - 30 kWh (Exclusive)";
        }

        return $"{component.BlockStart ?? 0}-{component.BlockEnd.Value} kWh";
    }

    private static int GetComponentSortOrder(TariffComponent component)
    {
        var type = component.ComponentType.ToLowerInvariant();

        if (type.Contains("fixed_charge"))
        {
            return 1;
        }

        if (type.StartsWith("energy"))
        {
            return type.Contains("lifeline") ? 0 : 2;
        }

        if (type.Contains("service_charge"))
        {
            return type.Contains("lifeline") ? 1 : 3;
        }

        if (type.Contains("demand_charge"))
        {
            return 4;
        }

        return 9;
    }

    private static string GetSltCategoryHeading(string category)
    {
        return category.ToUpperInvariant() switch
        {
            "SLT-LV" => "Low Voltage - LV",
            "SLT-MV" => "Medium Voltage - MV",
            "SLT-MV-HV" => "Medium Voltage / High Voltage - MV / HV",
            "SLT-MV2" => "Medium Voltage - MV-2",
            "SLT-HV" => "High Voltage - HV",
            "SLT-HV-MINES" => "High Voltage - Mines",
            "SLT-HV-STEEL-COMPANIES" => "High Voltage - Steel Companies",
            _ => category,
        };
    }

    private static string GetCalculationFlowText(bool isReverseCalculation)
    {
        return isReverseCalculation
            ? "Total Bill to Consumption"
            : "Consumption to Total Bill";
    }

    private static string FormatSignedAmount(decimal value)
    {
        var sign = value > 0m ? "+" : value < 0m ? "-" : string.Empty;
        return $"GHS {sign}{Math.Abs(value).ToString("N2")}";
    }

    private static string FormatSignedPercentage(decimal value)
    {
        var sign = value > 0m ? "+" : value < 0m ? "-" : string.Empty;
        return $"{sign}{Math.Abs(value).ToString("N2")}%";
    }

    private static string FormatRatePercentage(decimal value)
    {
        var normalizedValue = Math.Abs(value) <= 1m ? value * 100m : value;
        return $"{normalizedValue:N2}%";
    }
    private static string FormatLevyDisplay(int selectedCalendarYear, LevyRateRecord levy)
    {
    if (selectedCalendarYear == 1998)
    {
        return $"GHS {levy.LevyRate:N5}/kWh";
    }

    return FormatRatePercentage(levy.LevyRate);
    }
    private static string BuildTaxBasisNote(TariffBundle? bundle)
    {
        return "Tax is calculated as a percentage of the sum of energy charge and service charge.";
    }

    private static string BuildLevyBasisNote(int selectedCalendarYear, TariffBundle? bundle)
    {
        if (bundle is null || bundle.Levies.Count == 0)
        {
            return "Levies are applied as percentages of energy charge only.";
        }

        if (selectedCalendarYear <= 1998)
        {
            return "For this tariff year, levies are applied on the consumption basis defined for that period.";
        }

        return "Levies are applied as percentages of energy charge only.";
    }

    private static string GetMotionVariantClass(string key)
    {
        if (key.Contains("EV", StringComparison.OrdinalIgnoreCase))
        {
            return "is-ev";
        }

        if (key.StartsWith("Residential", StringComparison.OrdinalIgnoreCase))
        {
            return "is-residential";
        }

        if (key.StartsWith("Non-Residential", StringComparison.OrdinalIgnoreCase))
        {
            return "is-nonresidential";
        }

        if (key.StartsWith("SLT", StringComparison.OrdinalIgnoreCase))
        {
            return "is-slt";
        }

        return "is-generic";
    }

