    private static string GetCategoryIconMarkup(string category)
    {
        if (category.StartsWith("Residential", StringComparison.OrdinalIgnoreCase))
        {
            return "&#127968;";
        }

        if (category.StartsWith("Non-Residential", StringComparison.OrdinalIgnoreCase))
        {
            return "&#127970;";
        }

        if (category.StartsWith("SLT", StringComparison.OrdinalIgnoreCase))
        {
            return "&#9889;";
        }

        if (category.StartsWith("EV", StringComparison.OrdinalIgnoreCase))
        {
            return "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M7 15h10l1.4-4.2A2 2 0 0 0 16.5 8H8.2l-.7-1.4A2 2 0 0 0 5.7 5H4v2h1.7l3 6H8a2 2 0 0 0-2 2v2h1a2 2 0 1 0 4 0h4a2 2 0 1 0 4 0h1v-2a2 2 0 0 0-2-2h-1.1l.5-1.5H7Zm2 4.5a.75.75 0 1 1 0-1.5a.75.75 0 0 1 0 1.5Zm8 0a.75.75 0 1 1 0-1.5a.75.75 0 0 1 0 1.5ZM14 3l-2.8 4H13l-1 3l3.8-5H14Z\" fill=\"currentColor\"/></svg>";
        }

        return "&#128100;";
    }
